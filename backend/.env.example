# Copy to FlightBox/.env (next to this folder) and fill in real values.
# Do not put real secrets in this file — it is committed to Git.

CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
MAILBOX_EMAIL=
# GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0
# Document details: newest N messages per folder to scan for PDFs (default 2500, max 10000).
# DOCUMENT_DETAILS_FOLDER_MESSAGE_LIMIT=2500
# Faster scans (watch Graph throttling / 429): parallel attachment lists + PDF parses (defaults 6 / 5).
# GRAPH_ATTACHMENT_LIST_CONCURRENCY=6
# PDF_PARSE_CONCURRENCY=5
# Document details: when Import from/to is set, max messages loaded per folder (paginated) and max PDFs per email for that import.
# DOCUMENT_DETAILS_DATE_RANGE_MESSAGE_CAP=10000
# MAX_PDFS_PER_MESSAGE_DATE_RANGE=200
# Debug: show all rows when the same Doc no. appears more than once (no merge). Remove after testing.
# DISABLE_DOCUMENT_DETAILS_DEDUP=0
