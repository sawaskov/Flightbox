# Copy to .env for local development only. On Render, set these in the dashboard (Environment).
# Never commit a real .env file.

# --- Required (Microsoft Graph / Azure AD app registration) ---
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=

# Mailbox to read (UPN)
MAILBOX_EMAIL=

# --- Optional ---
# GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0
# MAX_DOCUMENT_PDF_MB=25
# MAX_PDFS_PER_MESSAGE=40
# MAX_QUERIES_XLSX_MB=12
# GRAPH_ATTACHMENT_LIST_CONCURRENCY=4
# PDF_PARSE_CONCURRENCY=3
# GRAPH_HTTP_MAX_ATTEMPTS=8

# Render sets PORT automatically; local default is 3000
# LISTEN_HOST=0.0.0.0
